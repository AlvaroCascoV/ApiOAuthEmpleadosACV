@model List<Empleado>

<h1>Compis</h1>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>
                IdEmpleado
            </th>
            <th>
                Apellido
            </th>
            <th>
                Oficio
            </th>
            <th>
                Salario
            </th>
            <th>
                IdDepartamento
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @item.IdEmpleado
                </td>
                <td>
                    @item.Apellido
                </td>
                <td>
                    @item.Oficio
                </td>
                <td>
                    @item.Salario
                </td>
                <td>
                    @item.IdDepartamento
                </td>
                <td>
                    <a asp-controller="Empleados" asp-action="Details" asp-route-idempleado="@item.IdEmpleado" class="btn btn-primary">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
