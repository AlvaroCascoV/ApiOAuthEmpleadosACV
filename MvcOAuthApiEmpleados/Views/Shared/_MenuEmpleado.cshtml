@if(Context.User.Identity.IsAuthenticated == true)
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Empleados" asp-action="Index">Empleados</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Managed" asp-action="Logout">Logout <strong>@Context.User.Identity.Name</strong></a>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Empleados" asp-action="Index">Login</a>
    </li>
}